  rdfs:seeAlso <nrepellent_fs1.ttl> .

<https://github.com/lucianodato/noise-repellent-stereo#new_fs1>
  a lv2:Plugin;
  lv2:binary <nrepellent_fs1@LIB_EXT@> ;
  rdfs:seeAlso <nrepellent_fs1#stereo.ttl> .

