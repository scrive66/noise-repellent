@prefix lv2:  <http://lv2plug.in/ns/lv2core#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<https://github.com/lucianodato/noise-repellent#new-x1>
  a lv2:Plugin;
  lv2:binary <nrepellent@LIB_EXT@> ;
  rdfs:seeAlso <nrepellent#x1.ttl> .
  
<https://github.com/lucianodato/noise-repellent-stereo#new-x1>
  a lv2:Plugin;
  lv2:binary <nrepellent@LIB_EXT@> ;
  rdfs:seeAlso <nrepellent#stereo-x1.ttl> .

